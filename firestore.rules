// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: posts
// Document ID: {postId}
// Fields:
//   - title: string (required, 1-100 chars)
//   - content: string (required, 1-10000 chars)
//   - category: string (required, 1-50 chars)
//   - imageUrl: string (optional, URL)
//   - authorId: string (required, UID)
//   - authorName: string (optional, 1-50 chars)
//   - createdAt: timestamp (required)
//   - updatedAt: timestamp (optional)
//
// Collection: settings
// Document ID: global
// Fields:
//   - siteName: string
//   - primaryColor: string
//   - secondaryColor: string
//   - heroTitle: string
//   - heroSubtitle: string
//   - footerText: string
//
// Collection: surveys
// Document ID: {surveyId}
// Fields:
//   - title: string (required)
//   - description: string (optional)
//   - formUrl: string (required, URL)
//   - isActive: bool (required)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "yelloboll@goedu.kr" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Simplified admin check for debugging/robustness
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "yelloboll@goedu.kr";
    }

    function isDocOwner(data) {
      return isAuthenticated() && request.auth.uid == data.authorId;
    }

    function isValidPost(data) {
      let validCategories = ['class', 'lunch', 'sports_club', 'festival', 'project', 'health_fitness', 'oasis', 'paps', 'character'];
      return data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.category in validCategories &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000)) &&
             (!('likesCount' in data) || data.likesCount is int) &&
             (!('viewCount' in data) || data.viewCount is int);
    }

    function isValidSurvey(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             data.formUrl is string && isValidUrl(data.formUrl) &&
             data.isActive is bool;
    }

    function isUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    function isValidCounterUpdate(postId) {
      // Case 1: View count update (anyone can increment)
      return (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) &&
              request.resource.data.viewCount == (resource.data.get('viewCount', 0) + 1)) ||
             // Case 2: Like count update
             (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) && 
              (
                // Subcase 2a: Authenticated (strict tracking)
                (isAuthenticated() &&
                 ((request.resource.data.likesCount == resource.data.get('likesCount', 0) + 1 &&
                   !exists(/databases/$(database)/documents/likes/$(request.auth.uid + "_" + postId)) &&
                   getAfter(/databases/$(database)/documents/likes/$(request.auth.uid + "_" + postId)) != null) ||
                  (request.resource.data.likesCount == resource.data.get('likesCount', 0) - 1 &&
                   exists(/databases/$(database)/documents/likes/$(request.auth.uid + "_" + postId)) &&
                   getAfter(/databases/$(database)/documents/likes/$(request.auth.uid + "_" + postId)) == null))) ||
                // Subcase 2b: Unauthenticated (allow +/- 1, but less secure as requested)
                (!isAuthenticated() && 
                 (request.resource.data.likesCount == resource.data.get('likesCount', 0) + 1 || 
                  (request.resource.data.likesCount == resource.data.get('likesCount', 0) - 1 && request.resource.data.likesCount >= 0)))
              ));
    }

    function isValidAppCounterUpdate(appId) {
      return (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) && 
              (
                // Subcase 2a: Authenticated (strict tracking)
                (isAuthenticated() &&
                 ((request.resource.data.likesCount == resource.data.get('likesCount', 0) + 1 &&
                   !exists(/databases/$(database)/documents/appLikes/$(request.auth.uid + "_" + appId)) &&
                   getAfter(/databases/$(database)/documents/appLikes/$(request.auth.uid + "_" + appId)) != null) ||
                  (request.resource.data.likesCount == resource.data.get('likesCount', 0) - 1 &&
                   exists(/databases/$(database)/documents/appLikes/$(request.auth.uid + "_" + appId)) &&
                   getAfter(/databases/$(database)/documents/appLikes/$(request.auth.uid + "_" + appId)) == null))) ||
                // Subcase 2b: Unauthenticated (allow +/- 1)
                (!isAuthenticated() && 
                 (request.resource.data.likesCount == resource.data.get('likesCount', 0) + 1 || 
                  (request.resource.data.likesCount == resource.data.get('likesCount', 0) - 1 && request.resource.data.likesCount >= 0)))
              ));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidPost(request.resource.data) && request.resource.data.authorId == request.auth.uid;
      allow update: if (isAdmin() && isValidPost(request.resource.data) && 
                       (isDocOwner(resource.data) || isAdmin()) &&
                       isUnchanged('authorId') && isUnchanged('createdAt')) ||
                       isValidCounterUpdate(postId);
      allow delete: if isAdmin();
    }

    match /likes/{likeId} {
      // likeId is {userId}_{postId}
      allow read: if true;
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      likeId == request.auth.uid + '_' + request.resource.data.postId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /appLikes/{likeId} {
      // likeId is {userId}_{appId}
      allow read: if true;
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      likeId == request.auth.uid + '_' + request.resource.data.appId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /highlights/{highlightId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /apps/{appId} {
      allow read: if true;
      allow update: if isValidAppCounterUpdate(appId) || isAdmin() || isSuperAdmin();
      allow create, delete: if isAdmin() || isSuperAdmin();
    }

    match /surveys/{surveyId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSurvey(request.resource.data);
      allow update: if isAdmin() && isValidSurvey(request.resource.data) && isUnchanged('createdAt');
      allow delete: if isAdmin();
    }

    match /analytics/visitors {
      allow read: if true;
      allow write: if true;
    }

    match /daily_stats/{date} {
      allow read: if true;
      allow write: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
